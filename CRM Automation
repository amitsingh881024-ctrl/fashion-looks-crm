name: CRM Automation

on:
  schedule:
    - cron: "0 3 * * *"   # Daily at 03:00 UTC
  workflow_dispatch:

jobs:
  automation:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - run: pip install -r requirements.txt

      - run: python automation/dashboard.py

      - run: python automation/lead_scoring.py

      - run: python automation/renewal_tracker.py

      - run: python automation/invoice_tracker.py

      - run: python automation/backup.py

      - uses: actions/upload-artifact@v4
        with:
          name: CRM-Reports
          path: reports/
